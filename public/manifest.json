{
    "name": "WeatherlyWave",
    "short_name": "WeatherlyWave",
    "description": "Advanced Weather Application with current conditions, forecasts, and air quality data",
    "start_url": "/",
    "display": "standalone",
    "theme_color": "#2196F3",
    "background_color": "#667eea",
    "orientation": "portrait-primary",
    "display_override": ["window-controls-overlay", "standalone"],
    "scope": "/",
    "lang": "en-US",
    "categories": ["weather", "lifestyle", "utilities"],
    "icons": [
        {
            "src": "WW.png",
            "sizes": "any",
            "type": "image/png",
            "purpose": "any maskable"
        },
        {
            "src": "WW.png",
            "sizes": "48x48",
            "type": "image/png"
        },
        {
            "src": "WW.png",
            "sizes": "72x72",
            "type": "image/png"
        },
        {
            "src": "WW.png",
            "sizes": "96x96",
            "type": "image/png"
        },
        {
            "src": "WW.png",
            "sizes": "144x144",
            "type": "image/png"
        },
        {
            "src": "WW.png",
            "sizes": "192x192",
            "type": "image/png"
        },
        {
            "src": "WW.png",
            "sizes": "512x512",
            "type": "image/png"
        }
    ],
    "shortcuts": [
        {
            "name": "Current Weather",
            "description": "View current weather conditions",
            "url": "/?view=current",
            "icons": [
                {
                    "src": "WW.png",
                    "sizes": "any",
                    "type": "image/png"
                }
            ]
        },
        {
            "name": "5-Day Forecast",
            "description": "View 5-day weather forecast",
            "url": "/?view=forecast",
            "icons": [
                {
                    "src": "WW.png",
                    "sizes": "any",
                    "type": "image/png"
                }
            ]
        },
        {
            "name": "Air Quality",
            "description": "Check air quality index",
            "url": "/?view=air-quality",
            "icons": [
                {
                    "src": "WW.png",
                    "sizes": "any",
                    "type": "image/png"
                }
            ]
        }
    ],
    "features": [
        "Cross Platform",
        "fast",
        "offline"
    ],
    "edge_side_panel": {
        "preferred_width": 400
    },
    "handle_links": "preferred",
    "launch_handler": {
        "client_mode": "navigate-existing"
    },
    "protocol_handlers": [
        {
            "protocol": "web+weather",
            "url": "/?location=%s"
        }
    ],
    "file_handlers": [
        {
            "action": "/",
            "accept": {
                "application/json": [".json"],
                "text/csv": [".csv"]
            }
        }
    ],
    "share_target": {
        "action": "/",
        "method": "GET",
        "params": {
            "title": "title",
            "text": "text",
            "url": "url"
        }
    },
    "related_applications": [],
    "prefer_related_applications": false
}
